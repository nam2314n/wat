# ============================================
# ARK Mobile Enhancement Toolkit
# .gitignore - Protección de archivos del juego
# ============================================
# Este archivo evita que subas archivos con copyright
# a GitHub por accidente. NUNCA quites estas reglas.

# --- ARCHIVOS DEL JUEGO (COPYRIGHT) ---
*.apk
*.xapk
*.obb
*.pak

# Archivos extraídos del juego
*_extracted/
*_decompiled/

# Assets de Unreal Engine
*.uasset
*.umap
*.uexp
*.ubulk

# Modelos y texturas del juego
*.fbx
*.obj
*.psk
*.psa
*.tga
*.dds
*.bmp

# Audio del juego
*.wav
*.ogg
*.mp3
*.wem
*.bnk

# --- ARCHIVOS TEMPORALES ---
Apktool/
build/
dist/
*.tmp
*.log

# --- SISTEMA ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE Y EDITORES ---
.vscode/
.idea/
*.swp
*.swo

# --- ENTORNO VIRTUAL / DEPENDENCIAS ---
node_modules/
__pycache__/
*.pyc

# --- ARCHIVOS GRANDES (>100MB) ---
# GitHub no permite archivos mayores a 100MB
*.zip
*.rar
*.7z
*.tar.gz

# --- INFORMACIÓN SENSIBLE ---
*.env
*.key
*.pem
